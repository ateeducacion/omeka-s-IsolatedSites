{
  "$schema": "https://ateeducacion.github.io/omeka-s-playground/assets/blueprints/blueprint-schema.json",
  "debug": {
    "enabled": true
  },
  "landingPage": "/admin",
  "siteOptions": {
    "title": "IsolatedSites Playground",
    "locale": "es",
    "timezone": "Atlantic/Canary"
  },
  "users": [
    {
      "username": "admin",
      "email": "admin@example.com",
      "password": "password",
      "role": "global_admin"
    },
    {
      "username": "editor",
      "email": "editor@example.com",
      "password": "password",
      "role": "editor",
      "settings": {
        "limit_to_granted_sites": false,
        "limit_to_own_assets": false
      }
    },
    {
      "username": "site_editor_a",
      "email": "editor.a@example.com",
      "password": "password",
      "role": "site_editor",
      "settings": {
        "limit_to_granted_sites": true,
        "limit_to_own_assets": true
      }
    },
    {
      "username": "site_editor_b",
      "email": "editor.b@example.com",
      "password": "password",
      "role": "site_editor",
      "settings": {
        "limit_to_granted_sites": true,
        "limit_to_own_assets": true
      }
    }
  ],
  "modules": [
    {
      "name": "Common",
      "state": "activate",
      "source": {
        "type": "url",
        "url": "https://github.com/Daniel-KM/Omeka-S-module-Common/archive/refs/heads/master.zip"
      }
    },
    {
      "name": "Log",
      "state": "activate",
      "source": {
        "type": "url",
        "url": "https://github.com/Daniel-KM/Omeka-S-module-Log/archive/refs/heads/master.zip"
      }
    },
    {
      "name": "IsolatedSites",
      "state": "activate",
      "source": {
        "type": "url",
        "url": "https://github.com/ateeducacion/omeka-s-IsolatedSites/archive/refs/heads/main.zip"
      }
    },
    {
      "name": "Impersonate",
      "state": "activate",
      "source": {
        "type": "url",
        "url": "https://github.com/ateeducacion/omeka-s-Impersonate/archive/refs/heads/main.zip"
      }
    }
  ],
  "itemSets": [
    {
      "title": "Team A Collection",
      "description": "Sample item set used to try out IsolatedSites filtering."
    },
    {
      "title": "Team B Collection",
      "description": "Second sample item set for isolation testing."
    }
  ],
  "items": [
    {
      "title": "Team A - Document 1",
      "description": "Sample item belonging to the Team A collection.",
      "creator": "Editor A",
      "itemSets": ["Team A Collection"],
      "sites": ["site-a"]
    },
    {
      "title": "Team A - Document 2",
      "description": "Another sample item in the Team A collection.",
      "creator": "Editor A",
      "itemSets": ["Team A Collection"],
      "sites": ["site-a"]
    },
    {
      "title": "Team B - Document 1",
      "description": "Sample item belonging to the Team B collection.",
      "creator": "Editor B",
      "itemSets": ["Team B Collection"],
      "sites": ["site-b"]
    },
    {
      "title": "Team B - Document 2",
      "description": "Another sample item in the Team B collection.",
      "creator": "Editor B",
      "itemSets": ["Team B Collection"],
      "sites": ["site-b"]
    }
  ],
  "sites": [
    {
      "title": "Site A (Team A)",
      "slug": "site-a",
      "theme": "default",
      "summary": "Site managed by Editor A. With isolation on, only Editor A and admins see it.",
      "isPublic": true,
      "setAsDefault": true,
      "permissions": [
        { "user": "editor.a@example.com", "role": "admin" }
      ]
    },
    {
      "title": "Site B (Team B)",
      "slug": "site-b",
      "theme": "default",
      "summary": "Site managed by Editor B. With isolation on, only Editor B and admins see it.",
      "isPublic": true,
      "permissions": [
        { "user": "editor.b@example.com", "role": "admin" }
      ]
    }
  ],
  "site": {
    "title": "Site A (Team A)",
    "slug": "site-a",
    "theme": "default",
    "summary": "Instalacion para probar el modulo IsolatedSites en Omeka S Playground.",
    "isPublic": true,
    "setAsDefault": true
  }
}
